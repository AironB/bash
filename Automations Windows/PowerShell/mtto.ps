@echo off
:: ========================================================================
:: NOMBRE: Limpieza_Profunda_Corporativa.bat
:: DESCRIPCIÓN: Automatiza la eliminación de archivos temporales del sistema,
::              caché de Windows Update, DNS, MS Teams, Office y Navegadores.
:: REQUISITOS: Requiere ejecutarse como Administrador.
:: ========================================================================

:: --- VERIFICACIÓN DE PRIVILEGIOS DE ADMINISTRADOR ---
net session >nul 2>&1
if %errorLevel% neq 0 (
    echo [ERROR] Este script necesita ejecutarse con privilegios de Administrador.
    echo Reintentando abrir como administrador...
    powershell -Command "Start-Process '%~f0' -Verb RunAs"
    exit /b
)

title Herramienta de Soporte Avanzado - SysAdmin Portfolio
color 0A

echo =======================================================================
echo     INICIANDO LIMPIEZA PROFUNDA Y RESOLUCIÓN DE CACHÉ EN EL EQUIPO
echo =======================================================================
echo.

:: --- 1. CIERRE DE PROCESOS CRÍTICOS ---
echo [*] Cerrando navegadores y aplicaciones de productividad para liberar archivos...
taskkill /f /im chrome.exe >nul 2>&1
taskkill /f /im msedge.exe >nul 2>&1
taskkill /f /im teams.exe >nul 2>&1
taskkill /f /im outlook.exe >nul 2>&1
taskkill /f /im winword.exe >nul 2>&1
taskkill /f /im excel.exe >nul 2>&1
taskkill /f /im explorer.exe >nul 2>&1
echo.

:: --- 2. CACHÉ DE APLICACIONES CORPORATIVAS (TEAMS Y OFFICE) ---
echo [*] Limpiando la caché de Microsoft Teams (Clásico y Nuevo)...
:: Teams Clásico
if exist "%appdata%\Microsoft\Teams" (
    del /f /s /q "%appdata%\Microsoft\Teams\*.*" >nul 2>&1
    for /d %%p in ("%appdata%\Microsoft\Teams\*") do rmdir /s /q "%%p" >nul 2>&1
)
:: Teams Nuevo (LocalPackages)
if exist "%localappdata%\Packages\MSTeams_8wekyb3d8bbwe" (
    del /f /s /q "%localappdata%\Packages\MSTeams_8wekyb3d8bbwe\LocalCache\Microsoft\MSTeams\*.*" >nul 2>&1
)

echo [*] Limpiando archivos temporales y caché de MS Office...
if exist "%localappdata%\Microsoft\Office\16.0\WebServiceCache" (
    del /f /s /q "%localappdata%\Microsoft\Office\16.0\WebServiceCache\*.*" >nul 2>&1
)
del /f /s /q "%localappdata%\Microsoft\Office\Spw\*.*" >nul 2>&1

:: --- 3. NAVEGADORES WEB (GOOGLE CHROME & MICROSOFT EDGE) ---
echo [*] Limpiando caché y datos temporales de Google Chrome...
if exist "%localappdata%\Google\Chrome\User Data\Default\Cache" (
    del /f /s /q "%localappdata%\Google\Chrome\User Data\Default\Cache\*.*" >nul 2>&1
    del /f /s /q "%localappdata%\Google\Chrome\User Data\Default\Code Cache\*.*" >nul 2>&1
)

echo [*] Limpiando caché y datos temporales de Microsoft Edge...
if exist "%localappdata%\Microsoft\Edge\User Data\Default\Cache" (
    del /f /s /q "%localappdata%\Microsoft\Edge\User Data\Default\Cache\*.*" >nul 2>&1
    del /f /s /q "%localappdata%\Microsoft\Edge\User Data\Default\Code Cache\*.*" >nul 2>&1
)

:: --- 4. TEMPORALES DE SISTEMA, PREFETCH Y LOGS ---
echo [*] Vaciando carpetas Temp de usuario y del sistema operativo...
del /f /s /q "%temp%\*.*" >nul 2>&1
for /d %%p in ("%temp%\*") do rmdir /s /q "%%p" >nul 2>&1

del /f /s /q "%systemroot%\Temp\*.*" >nul 2>&1
for /d %%p in ("%systemroot%\Temp\*") do rmdir /s /q "%%p" >nul 2>&1

echo [*] Limpiando directorio Prefetch y archivos de registro (.log) viejos...
del /f /s /q "%systemroot%\Prefetch\*.*" >nul 2>&1
for /d %%p in ("%systemroot%\Prefetch\*") do rmdir /s /q "%%p" >nul 2>&1
del /f /s /q "%systemroot%\*.log" >nul 2>&1

:: --- 5. CACHÉ DE SISTEMA DE WINDOWS UPDATE ---
echo [*] Deteniendo servicios para limpiar el histórico de descargas de Windows Update...
net stop wuauserv >nul 2>&1
net stop bits >nul 2>&1

del /f /s /q "%systemroot%\SoftwareDistribution\Download\*.*" >nul 2>&1
for /d %%p in ("%systemroot%\SoftwareDistribution\Download\*") do rmdir /s /q "%%p" >nul 2>&1

net start bits >nul 2>&1
net start wuauserv >nul 2>&1

:: --- 6. RED Y CONCLUSIÓN ---
echo [*] Solicitando renovación de caché de resolución DNS (FlushDNS)...
ipconfig /flushdns >nul 2>&1

echo [*] Restaurando la interfaz gráfica de usuario (Explorer)...
start explorer.exe
echo.

echo =======================================================================
echo     ¡PROCESO FINALIZADO! SISTEMA OPTIMIZADO Y CACHÉ PURGADA
echo =======================================================================
echo.
pause
exit